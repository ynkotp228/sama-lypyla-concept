---
import Layout from "../layouts/Layout.astro";
import PageHeader from "../components/PageHeader.astro";
import Form from "../components/ContactsComponents/Form.astro";
import ContactsBlock from "../components/ContactsComponents/ContactsBlock.astro";
import SocialMedia from "../components/ContactsComponents/SocialMedia.astro";
---
<Layout
  title="Контакти — Сама Ліпила"
  description="Зв'яжись із «Сама Ліпила»: телефон, пошта, соцмережі та форма для питань, відгуків і пропозицій. Львів і Вінниця."
>
  <PageHeader
    title="Контакти"
    description="Питання, відгуки, пропозиції — пиши, дзвони, чекаємо на тебе."
  />
  <div class="container mx-auto max-w-5xl px-4 py-16">
    <div class="grid gap-8 lg:grid-cols-2 lg:items-start">
      <!-- Ліва колонка: прямі контакти + соцмережі -->
      <div class="space-y-8">
        <ContactsBlock />
        <SocialMedia />
      </div>
      <!-- Права колонка: форма зв'язку -->
      <Form />
    </div>
  </div>
</Layout>
