---
// src/pages/cart.astro
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';

const base = import.meta.env.BASE_URL;

// Через expression-атрибут, інакше Astro з'їдає бекслеші у звичайному pattern="..."
const phonePattern = '^\\+380\\d{9}$';
---

<Layout title="Кошик — Сама Ліпила">
  <PageHeader title="Кошик" />

  <main class="container mx-auto max-w-5xl px-4 py-12 md:py-16">
    <!-- ─── Стан "порожньо" (показується за замовчуванням) ─── -->
    <div
      id="cart-empty"
      class="flex flex-col items-center gap-5 rounded-2xl bg-white py-16 text-center shadow-sm ring-1 ring-warm/10"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24"
        fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"
        stroke-linejoin="round" class="text-warm/25" aria-hidden="true"
      >
        <circle cx="8" cy="21" r="1"></circle>
        <circle cx="19" cy="21" r="1"></circle>
        <path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"></path>
      </svg>
      <p class="text-lg text-warm/70">Твій кошик поки порожній.</p>
      <a
        href={`${base}catalog/`}
        class="rounded-lg bg-accent-red px-5 py-2.5 text-sm font-medium text-white transition-colors hover:bg-primary"
      >
        Переглянути меню →
      </a>
    </div>

    <!-- ─── Стан "є товари" (заповнюється JS) ─── -->
    <div id="cart-content" hidden class="grid gap-8 lg:grid-cols-[1fr_20rem] lg:items-start">
      <ul id="cart-items" class="flex flex-col gap-4"></ul>

      <!-- ─── Підсумок + CTA ─── -->
      <aside class="rounded-2xl bg-white p-6 shadow-sm ring-1 ring-warm/10 lg:sticky lg:top-24">
        <h2 class="font-display text-lg font-semibold text-warm">Ваше замовлення</h2>

        <div class="mt-4 flex items-baseline justify-between border-t border-warm/10 pt-4">
          <span class="text-warm/70">Разом</span>
          <span class="font-display text-2xl font-semibold text-warm">
            <span id="cart-total">0</span>&nbsp;₴
          </span>
        </div>

        <button
          type="button"
          id="open-checkout-btn"
          class="mt-5 w-full rounded-lg bg-accent-red px-6 py-3 font-semibold text-white transition-colors hover:bg-primary"
        >
          Оформити замовлення
        </button>

        <p class="mt-3 text-center text-xs text-warm/50">
          Концепт-демо — оплата онлайн відсутня.
        </p>
      </aside>
    </div>

    <!-- ─── Діалог оформлення замовлення ─── -->
    <dialog
      id="checkout-dialog"
      data-state="form"
      aria-labelledby="checkout-dialog-title"
      class="m-auto w-full max-w-lg max-h-[90vh] overflow-y-auto rounded-2xl bg-cream p-0 text-warm shadow-2xl backdrop:bg-warm/60"
    >
      <div class="space-y-5 p-6">
        <header class="flex items-center justify-between border-b border-warm/10 pb-4">
          <h2 id="checkout-dialog-title" class="font-display text-xl font-semibold">
            Оформлення замовлення
          </h2>
          <form method="dialog" class="m-0">
            <button
              class="flex h-8 w-8 items-center justify-center rounded-full text-xl text-warm/50 transition-colors hover:bg-warm/5 hover:text-accent-red"
              aria-label="Закрити діалог"
            >×</button>
          </form>
        </header>

        <!-- ─── СТАН "form" ─── -->
        <div class="checkout-form-state">
          <form id="checkout-form" novalidate class="space-y-5">
            <!-- Контактні дані -->
            <fieldset class="space-y-3 rounded-xl border border-warm/15 p-4">
              <legend class="px-2 text-sm font-semibold text-warm/80">Контактні дані</legend>

              <label class="block">
                <span class="mb-1 block text-sm text-warm/70">Ім'я *</span>
                <input
                  type="text"
                  name="name"
                  required
                  autofocus
                  minlength="2"
                  class="w-full rounded-lg border border-warm/20 bg-white p-2.5 outline-none focus:border-primary focus:ring-2 focus:ring-primary/30"
                />
              </label>

              <label class="block">
                <span class="mb-1 block text-sm text-warm/70">Телефон *</span>
                <input
                  type="tel"
                  name="phone"
                  required
                  pattern={phonePattern}
                  placeholder="+380XXXXXXXXX"
                  class="w-full rounded-lg border border-warm/20 bg-white p-2.5 outline-none focus:border-primary focus:ring-2 focus:ring-primary/30"
                />
              </label>
            </fieldset>

            <!-- Спосіб отримання -->
            <fieldset class="space-y-2 rounded-xl border border-warm/15 p-4">
              <legend class="px-2 text-sm font-semibold text-warm/80">Спосіб отримання *</legend>

              <label class="flex cursor-pointer items-center gap-2.5">
                <input type="radio" name="method" value="pickup" required class="accent-primary" />
                <span>Самовивіз</span>
              </label>

              <label class="flex cursor-pointer items-center gap-2.5">
                <input type="radio" name="method" value="delivery" class="accent-primary" />
                <span>Доставка</span>
              </label>
            </fieldset>

            <!-- Місто -->
            <fieldset class="space-y-2 rounded-xl border border-warm/15 p-4">
              <legend class="px-2 text-sm font-semibold text-warm/80">Місто *</legend>

              <label class="flex cursor-pointer items-center gap-2.5">
                <input type="radio" name="city" value="lviv" required class="accent-primary" />
                <span>Львів</span>
              </label>

              <label class="flex cursor-pointer items-center gap-2.5">
                <input type="radio" name="city" value="vinnytsia" class="accent-primary" />
                <span>Вінниця</span>
              </label>
            </fieldset>

            <!-- Точка самовивозу (показується для "Самовивіз") -->
            <fieldset id="pickup-fields" disabled class="hidden space-y-3 rounded-xl border border-warm/15 p-4">
              <legend class="px-2 text-sm font-semibold text-warm/80">Точка самовивозу *</legend>

              <label class="block">
                <span class="mb-1 block text-sm text-warm/70">Оберіть точку</span>
                <select
                  name="pointId"
                  required
                  class="w-full rounded-lg border border-warm/20 bg-white p-2.5 outline-none focus:border-primary focus:ring-2 focus:ring-primary/30"
                >
                  <option value="" disabled selected>Спочатку оберіть місто</option>
                </select>
              </label>
            </fieldset>

            <!-- Адреса доставки (показується для "Доставка") -->
            <fieldset id="delivery-fields" disabled class="hidden space-y-3 rounded-xl border border-warm/15 p-4">
              <legend class="px-2 text-sm font-semibold text-warm/80">Адреса доставки *</legend>

              <label class="block">
                <span class="mb-1 block text-sm text-warm/70">Вулиця, будинок, квартира</span>
                <textarea
                  name="deliveryAddress"
                  required
                  rows="2"
                  class="w-full rounded-lg border border-warm/20 bg-white p-2.5 outline-none focus:border-primary focus:ring-2 focus:ring-primary/30"
                ></textarea>
              </label>
            </fieldset>

            <!-- Коментар -->
            <label class="block">
              <span class="mb-1 block text-sm font-semibold text-warm/80">Коментар (опц.)</span>
              <textarea
                name="comment"
                rows="2"
                placeholder="Зручний час для зв'язку, особливі побажання…"
                class="w-full rounded-lg border border-warm/20 bg-white p-2.5 outline-none focus:border-primary focus:ring-2 focus:ring-primary/30"
              ></textarea>
            </label>

            <div class="flex flex-col gap-3 sm:flex-row">
              <button
                type="submit"
                class="rounded-lg bg-accent-red px-6 py-3 font-semibold text-white transition-colors hover:bg-primary"
              >
                Сформувати замовлення
              </button>

              <button
                type="button"
                id="reset-btn"
                class="rounded-lg border border-warm/20 px-6 py-3 font-medium text-warm transition-colors hover:bg-warm/5"
              >
                Очистити форму
              </button>
            </div>
          </form>
        </div>

        <!-- ─── СТАН "preview" ─── -->
        <div class="checkout-preview-state">
          <pre
            id="message-preview"
            class="max-h-96 overflow-y-auto whitespace-pre-wrap rounded-lg border border-warm/15 bg-white p-4 font-mono text-sm text-warm"
          ></pre>

          <button
            type="button"
            id="back-to-form-btn"
            class="mt-4 text-sm text-deep-blue transition-colors hover:text-primary hover:underline"
          >
            ← Назад до форми
          </button>

          <div class="mt-4 flex flex-col gap-2 sm:flex-row">
            <button
              type="button"
              id="copy-btn"
              class="rounded-lg bg-accent-red px-5 py-2.5 text-center font-medium text-white transition-colors hover:bg-primary"
            >
              Копіювати
            </button>

            <a
              id="viber-link"
              href="#"
              target="_blank"
              rel="noopener noreferrer"
              class="rounded-lg border border-warm/20 px-5 py-2.5 text-center font-medium text-warm transition-colors hover:bg-warm/5"
            >
              Viber (демо)
            </a>

            <a
              id="telegram-link"
              href="#"
              target="_blank"
              rel="noopener noreferrer"
              class="rounded-lg border border-warm/20 px-5 py-2.5 text-center font-medium text-warm transition-colors hover:bg-warm/5"
            >
              Telegram (демо)
            </a>
          </div>

          <p
            role="note"
            class="mt-4 flex items-start gap-2 rounded-lg border border-primary/20 bg-primary/5 p-3 text-sm text-warm/80"
          >
            <span aria-hidden="true">ℹ</span>
            <span>Це концепт-демо: реальне замовлення не буде надіслане.</span>
          </p>
        </div>
      </div>
    </dialog>
  </main>

  <style>
    /* Прогресивне покращення: якщо JS не завантажився, користувач
       побачить хоча б форму. JS перемикає data-state. */

    /* state=form: ховаємо preview */
    #checkout-dialog[data-state="form"] .checkout-preview-state {
      display: none;
    }

    /* state=preview: ховаємо форму */
    #checkout-dialog[data-state="preview"] .checkout-form-state {
      display: none;
    }
  </style>

  <script>
    import {
      getCart,
      getCartTotal,
      removeFromCart,
      updateQuantity,
      generateOrderMessage,
      buildViberLink,
      buildTelegramLink,
    } from '../scripts/cart.js';
    import { getPointsByCity, getPointById } from '../data/locations';
    import { products } from '../data/products';

    // ─────────────────────────────────────────────
    // Список товарів кошика
    // ─────────────────────────────────────────────
    const emptyEl = document.getElementById('cart-empty')!;
    const contentEl = document.getElementById('cart-content')!;
    const itemsEl = document.getElementById('cart-items')!;
    const totalEl = document.getElementById('cart-total')!;

    function renderCart() {
      const cart = getCart();

      if (cart.length === 0) {
        emptyEl.hidden = false;
        contentEl.hidden = true;
        return;
      }

      emptyEl.hidden = true;
      contentEl.hidden = false;

      // Рендер списку
      itemsEl.innerHTML = cart.map((item: { id: string; quantity: number }) => {
        const product = products.find((p) => p.id === item.id);
        if (!product) return ''; // товар видалений з продукт-каталога

        return `
          <li class="cart-item flex items-center gap-4 rounded-2xl bg-white p-3 shadow-sm ring-1 ring-warm/10 sm:p-4" data-id="${product.id}">
            <img src="${product.image.src}" alt="${product.alt}" width="96" height="72" class="h-16 w-24 shrink-0 rounded-xl object-cover" />
            <div class="min-w-0 flex-1">
              <h3 class="truncate font-medium text-warm">${product.name}</h3>
              <p class="mt-0.5 text-sm text-warm/60">${product.weight} · <span class="font-semibold text-warm">${product.price} ₴</span></p>
            </div>
            <div class="flex items-center gap-1 rounded-lg ring-1 ring-warm/15">
              <button type="button" data-action="decrease" aria-label="Зменшити кількість" class="flex h-8 w-8 items-center justify-center rounded-l-lg text-lg text-warm/70 transition-colors hover:bg-warm/5 hover:text-primary">−</button>
              <span class="w-6 text-center text-sm font-medium text-warm">${item.quantity}</span>
              <button type="button" data-action="increase" aria-label="Збільшити кількість" class="flex h-8 w-8 items-center justify-center rounded-r-lg text-lg text-warm/70 transition-colors hover:bg-warm/5 hover:text-primary">+</button>
            </div>
            <button type="button" data-action="remove" aria-label="Видалити ${product.name}" class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full text-xl text-warm/40 transition-colors hover:bg-accent-red/10 hover:text-accent-red">×</button>
          </li>
        `;
      }).join('');

      // Підрахунок суми
      totalEl.textContent = String(getCartTotal(products));
    }

    // Делегування подій всередині списку
    itemsEl.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest('button[data-action]') as HTMLButtonElement | null;
      if (!btn) return;

      const li = btn.closest('.cart-item') as HTMLElement | null;
      if (!li) return;
      const id = li.dataset.id!;
      const action = btn.dataset.action;

      const cart = getCart();
      const item = cart.find((i: { id: string }) => i.id === id);
      if (!item) return;

      if (action === 'increase') updateQuantity(id, item.quantity + 1);
      if (action === 'decrease') updateQuantity(id, item.quantity - 1);
      if (action === 'remove') removeFromCart(id);
    });

    // Initial render + підписка на оновлення
    renderCart();
    window.addEventListener('cart-updated', renderCart);

    // ─────────────────────────────────────────────
    // Діалог оформлення замовлення
    // ─────────────────────────────────────────────
    const openBtn = document.getElementById('open-checkout-btn') as HTMLButtonElement | null;
    const dialog = document.getElementById('checkout-dialog') as HTMLDialogElement | null;
    const form = document.getElementById('checkout-form') as HTMLFormElement | null;

    if (openBtn && dialog && form) {
      const pickupFields = document.getElementById('pickup-fields') as HTMLFieldSetElement;
      const deliveryFields = document.getElementById('delivery-fields') as HTMLFieldSetElement;
      const pointSelect = pickupFields.querySelector('select') as HTMLSelectElement;
      const resetBtn = document.getElementById('reset-btn') as HTMLButtonElement;
      const dialogTitle = document.getElementById('checkout-dialog-title') as HTMLHeadingElement;
      const previewEl = document.getElementById('message-preview') as HTMLPreElement;
      const viberLink = document.getElementById('viber-link') as HTMLAnchorElement;
      const telegramLink = document.getElementById('telegram-link') as HTMLAnchorElement;
      const copyBtn = document.getElementById('copy-btn') as HTMLButtonElement;
      const backBtn = document.getElementById('back-to-form-btn') as HTMLButtonElement;
      const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;

      // ─── Відкриття діалогу ───
      openBtn.addEventListener('click', () => {
        dialog.showModal();
      });

      // ─── Закриття діалогу: повернути state на 'form' ───
      dialog.addEventListener('close', () => {
        dialog.dataset.state = 'form';
        dialogTitle.textContent = 'Оформлення замовлення';
      });

      // ─── Закриття по Escape (страховка, щоб подія не пішла далі в menu.js) ───
      dialog.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') {
          e.preventDefault();
          dialog.close();
        }
      });

      // ─── Перемикання полів за способом отримання / містом ───
      form.addEventListener('change', (e) => {
        const target = e.target as HTMLInputElement;

        if (target.name === 'method') {
          const method = (form.elements.namedItem('method') as RadioNodeList).value;
          const isPickup = method === 'pickup';
          const isDelivery = method === 'delivery';

          // disabled-поля не беруть участі у валідації та submit
          pickupFields.disabled = !isPickup;
          pickupFields.classList.toggle('hidden', !isPickup);
          deliveryFields.disabled = !isDelivery;
          deliveryFields.classList.toggle('hidden', !isDelivery);
        }

        if (target.name === 'city') {
          const city = (form.elements.namedItem('city') as RadioNodeList).value as 'lviv' | 'vinnytsia';
          renderPoints(city);
        }
      });

      function renderPoints(city: 'lviv' | 'vinnytsia') {
        const points = getPointsByCity(city);
        pointSelect.innerHTML =
          '<option value="" disabled selected>Оберіть точку</option>' +
          points.map((p) => `<option value="${p.id}">${p.address}</option>`).join('');
      }

      // ─── Submit → формуємо повідомлення замовлення ───
      form.addEventListener('submit', (e) => {
        e.preventDefault();

        if (!form.checkValidity()) {
          form.reportValidity();
          return;
        }

        const cart = getCart();
        if (cart.length === 0) {
          // edge case: кошик спорожнів між відкриттям діалогу та submit
          alert('Кошик порожній. Поверніться на сторінку та додайте товари.');
          dialog.close();
          return;
        }

        const fd = new FormData(form);
        const method = String(fd.get('method')) as 'pickup' | 'delivery';
        const pointId = String(fd.get('pointId') ?? '');

        // Формат formData очікує generateOrderMessage (cart.js)
        const data = {
          name: String(fd.get('name') ?? '').trim(),
          phone: String(fd.get('phone') ?? '').trim(),
          city: String(fd.get('city') ?? '') as 'lviv' | 'vinnytsia',
          method,
          pointAddress:
            method === 'pickup' ? getPointById(pointId)?.address ?? '' : '',
          deliveryAddress:
            method === 'delivery' ? String(fd.get('deliveryAddress') ?? '').trim() : '',
          comment: String(fd.get('comment') ?? '').trim(),
        };

        const message = generateOrderMessage(cart, products, data);

        previewEl.textContent = message;
        viberLink.href = buildViberLink('380000000000', message);
        telegramLink.href = buildTelegramLink('samalipyla_demo', message);

        dialog.dataset.state = 'preview';
        dialogTitle.textContent = 'Ваше замовлення готове';

        copyBtn.focus();
      });

      // ─── Скидання форми ───
      resetBtn.addEventListener('click', () => {
        form.reset();
        pickupFields.disabled = true;
        pickupFields.classList.add('hidden');
        deliveryFields.disabled = true;
        deliveryFields.classList.add('hidden');
      });

      // ─── Назад до форми ───
      backBtn.addEventListener('click', () => {
        dialog.dataset.state = 'form';
        dialogTitle.textContent = 'Оформлення замовлення';
        submitBtn.focus();
      });

      // ─── Копіювання повідомлення ───
      let copyResetTimer: number | null = null;

      copyBtn.addEventListener('click', async () => {
        const text = previewEl.textContent ?? '';
        if (!text) return;

        try {
          await navigator.clipboard.writeText(text);
          copyBtn.textContent = 'Скопійовано ✓';
        } catch (err) {
          console.warn('Clipboard API failed:', err);
          window.prompt('Скопіюйте вручну:', text);
          return;
        }

        if (copyResetTimer !== null) clearTimeout(copyResetTimer);
        copyResetTimer = window.setTimeout(() => {
          copyBtn.textContent = 'Копіювати';
          copyResetTimer = null;
        }, 2000);
      });
    }
  </script>
</Layout>
