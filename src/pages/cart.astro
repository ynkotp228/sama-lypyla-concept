---
// src/pages/cart.astro
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';

const base = import.meta.env.BASE_URL;
---

<Layout title="Кошик — Сама Ліпила">
  <PageHeader title="Кошик" />

  <main class="container mx-auto max-w-5xl px-4 py-12 md:py-16">
    <!-- ─── Стан "порожньо" (показується за замовчуванням) ─── -->
    <div
      id="cart-empty"
      class="flex flex-col items-center gap-5 rounded-2xl bg-white py-16 text-center shadow-sm ring-1 ring-warm/10"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24"
        fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"
        stroke-linejoin="round" class="text-warm/25" aria-hidden="true"
      >
        <circle cx="8" cy="21" r="1"></circle>
        <circle cx="19" cy="21" r="1"></circle>
        <path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"></path>
      </svg>
      <p class="text-lg text-warm/70">Твій кошик поки порожній.</p>
      <a
        href={`${base}catalog/`}
        class="rounded-lg bg-accent-red px-5 py-2.5 text-sm font-medium text-white transition-colors hover:bg-primary"
      >
        Переглянути меню →
      </a>
    </div>

    <!-- ─── Стан "є товари" (заповнюється JS) ─── -->
    <div id="cart-content" hidden class="grid gap-8 lg:grid-cols-[1fr_20rem] lg:items-start">
      <ul id="cart-items" class="flex flex-col gap-4"></ul>

      <div class="rounded-2xl bg-white p-6 shadow-sm ring-1 ring-warm/10 lg:sticky lg:top-24">
        <div class="flex items-baseline justify-between border-b border-warm/10 pb-4">
          <span class="text-warm/70">Разом</span>
          <span class="font-display text-2xl font-semibold text-warm">
            <span id="cart-total">0</span> ₴
          </span>
        </div>

        <button
          type="button"
          id="open-checkout-btn"
          class="mt-4 px-6 py-3 border rounded font-semibold w-full"
        ><!-- TODO: основной CTA-цвет -->
          Оформити замовлення
        </button>
      </div>
    </div>

    <!-- ─── Діалог оформлення замовлення ─── -->
    <dialog
      id="checkout-dialog"
      data-state="form"
      class="m-auto w-full max-w-lg max-h-[90vh] overflow-y-auto rounded p-0 backdrop:bg-black/50"
    >
      <div class="p-6 space-y-4">
        <header class="flex items-center justify-between border-b pb-3">
          <h2 id="checkout-dialog-title" class="text-xl font-semibold">
            Оформлення замовлення
          </h2>
          <form method="dialog" class="m-0">
            <button class="px-3 py-1 border rounded" aria-label="Закрити діалог">
              Закрити
            </button>
          </form>
        </header>

        <!-- ─── СТАН "form" ─── -->
        <div class="checkout-form-state">
          <form id="checkout-form" novalidate class="space-y-6">
            <fieldset class="border p-4 rounded space-y-3"><!-- TODO: цвета -->
              <legend class="px-2 font-semibold">Контактні дані</legend>

              <label class="block">
                <span class="block mb-1">Ім'я *</span>
                <input
                  type="text"
                  name="name"
                  required
                  minlength="2"
                  class="w-full border rounded p-2"
                />
              </label>

              <label class="block">
                <span class="block mb-1">Телефон *</span>
                <input
                  type="tel"
                  name="phone"
                  required
                  pattern="^\\+380\\d{9}$"
                  placeholder="+380XXXXXXXXX"
                  class="w-full border rounded p-2"
                />
              </label>
            </fieldset>

            <fieldset class="border p-4 rounded space-y-2">
              <legend class="px-2 font-semibold">Спосіб отримання *</legend>

              <label class="flex items-center gap-2">
                <input type="radio" name="method" value="pickup" required />
                <span>Самовивіз</span>
              </label>

              <label class="flex items-center gap-2">
                <input type="radio" name="method" value="delivery" />
                <span>Доставка</span>
              </label>
            </fieldset>

            <fieldset class="border p-4 rounded space-y-2">
              <legend class="px-2 font-semibold">Місто *</legend>

              <label class="flex items-center gap-2">
                <input type="radio" name="city" value="lviv" required />
                <span>Львів</span>
              </label>

              <label class="flex items-center gap-2">
                <input type="radio" name="city" value="vinnytsia" />
                <span>Вінниця</span>
              </label>
            </fieldset>

            <fieldset id="pickup-fields" disabled class="hidden border p-4 rounded space-y-3">
              <legend class="px-2 font-semibold">Точка самовивозу *</legend>

              <label class="block">
                <span class="block mb-1">Оберіть точку</span>
                <select name="pointId" required class="w-full border rounded p-2">
                  <option value="" disabled selected>Спочатку оберіть місто</option>
                </select>
              </label>
            </fieldset>

            <fieldset id="delivery-fields" disabled class="hidden border p-4 rounded space-y-3">
              <legend class="px-2 font-semibold">Адреса доставки *</legend>

              <label class="block">
                <span class="block mb-1">Вулиця, будинок, квартира</span>
                <textarea
                  name="deliveryAddress"
                  required
                  rows="2"
                  class="w-full border rounded p-2"
                ></textarea>
              </label>
            </fieldset>

            <label class="block">
              <span class="block mb-1 font-semibold">Коментар (опц.)</span>
              <textarea
                name="comment"
                rows="2"
                class="w-full border rounded p-2"
                placeholder="Зручний час для зв'язку, особливі побажання…"
              ></textarea>
            </label>

            <div class="flex flex-col sm:flex-row gap-3">
              <button
                type="submit"
                class="px-6 py-3 border rounded font-semibold"
              ><!-- TODO: основной CTA-цвет -->
                Сформувати замовлення
              </button>

              <button
                type="button"
                id="reset-btn"
                class="px-6 py-3 border rounded"
              ><!-- TODO: вторичный/outline -->
                Очистити форму
              </button>
            </div>
          </form>
        </div>

        <!-- ─── СТАН "preview" ─── -->
        <div class="checkout-preview-state">
          <!-- день 4: pre, кнопки Назад/Копіювати/Viber/Telegram, info-banner -->
          <p class="text-sm opacity-60">Превʼю зʼявиться після відправки форми (день 4).</p>
        </div>
      </div>
    </dialog>
  </main>

  <style>
    /* По умолчанию оба блока видимы — на случай если JS не загрузился,
       пользователь хотя бы увидит форму. Прогрессивное улучшение. */

    /* state=form: прячем preview */
    #checkout-dialog[data-state="form"] .checkout-preview-state {
      display: none;
    }

    /* state=preview: прячем форму */
    #checkout-dialog[data-state="preview"] .checkout-form-state {
      display: none;
    }
  </style>

  <script>
    import { getCart, getCartTotal, removeFromCart, updateQuantity } from '../scripts/cart.js';
    import { getPointsByCity } from '../data/locations';
    import { products } from '../data/products';

    // ─────────────────────────────────────────────
    // Список товарів кошика
    // ─────────────────────────────────────────────
    const emptyEl = document.getElementById('cart-empty');
    const contentEl = document.getElementById('cart-content');
    const itemsEl = document.getElementById('cart-items');
    const totalEl = document.getElementById('cart-total');

    function renderCart() {
      const cart = getCart();

      if (cart.length === 0) {
        emptyEl.hidden = false;
        contentEl.hidden = true;
        return;
      }

      emptyEl.hidden = true;
      contentEl.hidden = false;

      // Рендер списку
      itemsEl.innerHTML = cart.map(item => {
        const product = products.find(p => p.id === item.id);
        if (!product) return ''; // товар видалений з продукт-каталога

        return `
          <li class="cart-item flex items-center gap-4 rounded-2xl bg-white p-3 shadow-sm ring-1 ring-warm/10 sm:p-4" data-id="${product.id}">
            <img src="${product.image.src}" alt="${product.alt}" width="96" height="72" class="h-16 w-24 shrink-0 rounded-xl object-cover" />
            <div class="min-w-0 flex-1">
              <h3 class="truncate font-medium text-warm">${product.name}</h3>
              <p class="mt-0.5 text-sm text-warm/60">${product.weight} · <span class="font-semibold text-warm">${product.price} ₴</span></p>
            </div>
            <div class="flex items-center gap-1 rounded-lg ring-1 ring-warm/15">
              <button type="button" data-action="decrease" aria-label="Зменшити кількість" class="flex h-8 w-8 items-center justify-center rounded-l-lg text-lg text-warm/70 transition-colors hover:bg-warm/5 hover:text-primary">−</button>
              <span class="w-6 text-center text-sm font-medium text-warm">${item.quantity}</span>
              <button type="button" data-action="increase" aria-label="Збільшити кількість" class="flex h-8 w-8 items-center justify-center rounded-r-lg text-lg text-warm/70 transition-colors hover:bg-warm/5 hover:text-primary">+</button>
            </div>
            <button type="button" data-action="remove" aria-label="Видалити ${product.name}" class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full text-xl text-warm/40 transition-colors hover:bg-accent-red/10 hover:text-accent-red">×</button>
          </li>
        `;
      }).join('');

      // Підрахунок суми
      totalEl.textContent = String(getCartTotal(products));
    }

    // Делегування подій всередині списку
    itemsEl.addEventListener('click', (e) => {
      const btn = e.target.closest('button[data-action]');
      if (!btn) return;

      const li = btn.closest('.cart-item');
      const id = li.dataset.id;
      const action = btn.dataset.action;

      const cart = getCart();
      const item = cart.find(i => i.id === id);
      if (!item) return;

      if (action === 'increase') updateQuantity(id, item.quantity + 1);
      if (action === 'decrease') updateQuantity(id, item.quantity - 1);
      if (action === 'remove') removeFromCart(id);
    });

    // Initial render + підписка на оновлення
    renderCart();
    window.addEventListener('cart-updated', renderCart);

    // ─────────────────────────────────────────────
    // Діалог оформлення замовлення
    // ─────────────────────────────────────────────
    const openBtn = document.getElementById('open-checkout-btn') as HTMLButtonElement | null;
    const dialog = document.getElementById('checkout-dialog') as HTMLDialogElement | null;
    const form = document.getElementById('checkout-form') as HTMLFormElement | null;

    if (openBtn && dialog && form) {
      const pickupFields = document.getElementById('pickup-fields') as HTMLFieldSetElement;
      const deliveryFields = document.getElementById('delivery-fields') as HTMLFieldSetElement;
      const pointSelect = pickupFields.querySelector('select') as HTMLSelectElement;
      const resetBtn = document.getElementById('reset-btn') as HTMLButtonElement;
      const dialogTitle = document.getElementById('checkout-dialog-title') as HTMLHeadingElement;

      // ─── Відкриття діалогу ───
      openBtn.addEventListener('click', () => {
        dialog.showModal();
      });

      // ─── Закриття діалогу: повернути state на 'form' ───
      dialog.addEventListener('close', () => {
        dialog.dataset.state = 'form';
        dialogTitle.textContent = 'Оформлення замовлення';
      });

      // ─── Закриття по Escape (страховка, якщо нативний cancel не спрацював) ───
      dialog.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') {
          e.preventDefault(); // не даємо події піти далі (напр. у menu.js)
          dialog.close();
        }
      });

      // ─── Перемикання полів за способом отримання / містом ───
      form.addEventListener('change', (e) => {
        const target = e.target as HTMLInputElement;

        if (target.name === 'method') {
          const method = (form.elements.namedItem('method') as RadioNodeList).value;
          const isPickup = method === 'pickup';
          const isDelivery = method === 'delivery';

          pickupFields.disabled = !isPickup;
          pickupFields.classList.toggle('hidden', !isPickup);
          deliveryFields.disabled = !isDelivery;
          deliveryFields.classList.toggle('hidden', !isDelivery);
        }

        if (target.name === 'city') {
          const city = (form.elements.namedItem('city') as RadioNodeList).value as 'lviv' | 'vinnytsia';
          renderPoints(city);
        }
      });

      function renderPoints(city: 'lviv' | 'vinnytsia') {
        const points = getPointsByCity(city);
        pointSelect.innerHTML =
          '<option value="" disabled selected>Оберіть точку</option>' +
          points.map(p => `<option value="${p.id}">${p.address}</option>`).join('');
      }

      // ─── Submit — поки заглушка ───
      form.addEventListener('submit', (e) => {
        e.preventDefault();
        if (!form.checkValidity()) {
          form.reportValidity();
          return;
        }
        const formData = Object.fromEntries(new FormData(form));
        console.log('Form is valid. Data:', formData);
        // TODO день 4: построить сообщение, обогатить formData, открыть превью
      });

      // ─── Скидання форми ───
      resetBtn.addEventListener('click', () => {
        form.reset();
        pickupFields.disabled = true;
        pickupFields.classList.add('hidden');
        deliveryFields.disabled = true;
        deliveryFields.classList.add('hidden');
      });
    }
  </script>
</Layout>
