---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
import { getPointsByCity, type CityId } from '../data/locations';

// Посилання на Google Maps для конкретної точки (місто + адреса).
const mapLink = (city: string, address: string) =>
  `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(`Сама Ліпила, ${city}, ${address}`)}`;

// Міста для показу + їхні точки з даних (src/data/locations.ts).
// Mock-дані про зону доставки — для concept-проєкту. Структура повторюється для обох міст.
const cities = (
  [
    {
      id: 'lviv',
      name: 'Львів',
      delivery: "У межах об'їзної. Замовлення від 200 ₴. Очікуваний час до 90 хвилин.",
    },
    {
      id: 'vinnytsia',
      name: 'Вінниця',
      delivery: "Центральні райони: Замостя, Вишенька, Слов'янка. Замовлення від 200 ₴. Очікуваний час до 90 хвилин.",
    },
  ] satisfies { id: CityId; name: string; delivery: string }[]
).map((city) => ({ ...city, points: getPointsByCity(city.id) }));

const totalPoints = cities.reduce((sum, c) => sum + c.points.length, 0);
---

<Layout
  title="Локації — Сама Ліпила"
  description={`${totalPoints} точок самовивозу у Львові та Вінниці та зони доставки «Сама Ліпила». Дивись адреси на мапі.`}
>
  <PageHeader
    title="Локації"
    description={`${totalPoints} точок самовивозу у Львові та Вінниці. Доставка у межах основних районів.`}
    secondary="Графік роботи: Щодня з 9:00 до 21:00."
  />
  

  <main class="container mx-auto max-w-5xl px-4 py-16 md:py-24">
    {cities.map((city) => (
      <!-- ВАЖЛИВО: id — це якір з тизера локацій на головній (LocationsTeaser) -->
      <section id={city.id} aria-labelledby={`${city.id}-heading`} class="mb-16 scroll-mt-24 last:mb-0">
        <header class="mb-6 flex items-baseline gap-3">
          <h2 id={`${city.id}-heading`} class="font-display text-3xl font-semibold text-warm md:text-4xl">
            {city.name}
          </h2>
          <span class="text-lg text-warm/50">
            {city.points.length} {city.points.length === 1 ? 'точка' : 'точок'}
          </span>
        </header>

        <!-- Інфо-смуга про доставку: перед сіткою точок самовивозу -->
        <aside
          aria-labelledby={`${city.id}-delivery-heading`}
          class="mb-8 flex items-start gap-3 rounded-2xl border border-primary/20 bg-primary/5 p-5 md:p-6"
        >
          <span aria-hidden="true" class="text-2xl leading-none">🚚</span>
          <div>
            <h3 id={`${city.id}-delivery-heading`} class="font-display text-lg font-semibold text-warm">
              Зона доставки
            </h3>
            <p class="mt-1 text-sm text-warm/80 md:text-base">{city.delivery}</p>
          </div>
        </aside>

        <!-- Підзаголовок над сіткою — знімає двозначність "що це за картки" -->
        <h3 class="mb-4 font-display text-xl font-semibold text-warm">Самовивіз</h3>

        <ul class="grid grid-cols-1 gap-4 sm:grid-cols-2 md:gap-6 lg:grid-cols-3">
          {city.points.map((point) => (
            <li>
              <a
                href={mapLink(city.name, point.address)}
                target="_blank"
                rel="noopener noreferrer"
                class="group flex h-full flex-col justify-between gap-4 rounded-2xl border border-warm/10 bg-white p-6 transition hover:border-primary hover:shadow-lg"
              >
                <div>
                  <address class="not-italic">
                    <span class="block font-display text-lg font-semibold leading-snug text-warm">
                      {point.address}
                    </span>
                    {point.note && (
                      <span class="mt-1 block text-sm text-warm/60">{point.note}</span>
                    )}
                  </address>
                </div>
                <span class="inline-flex items-center gap-1.5 text-sm font-medium text-accent-red transition group-hover:underline">
                  Відкрити в Картах
                  <span class="transition group-hover:translate-x-1" aria-hidden="true">→</span>
                </span>
              </a>
            </li>
          ))}
        </ul>
      </section>
    ))}
  </main>
</Layout>