---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets'
import logo from '../assets/images/logo.png';
const base = import.meta.env.BASE_URL;  
---
<Layout title=" 404 - Сторінку не знайдено">
    <main>
        <Image 
            src={logo}
            alt=""
            width={100}
            height={100}
            loading="eager"
        />
        <p class=" "> Помилка 404</p>
        <h1 class=" "> Сторінку не знайдено </h1>
        <p class=" "> Вибачте, але сторінка, яку ви шукаєте, не існує. </p>
        <a href={`${base}`} class="text-blue-500 hover:text-blue-700">
            Повернутися на головну
        </a>
    </main>
</Layout>