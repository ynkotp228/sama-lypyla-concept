---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets'
import logo from '../assets/images/logoSL.png';
const base = import.meta.env.BASE_URL;
---
<Layout title="404 — Сторінку не знайдено">
    <main class="flex flex-1 flex-col items-center justify-center gap-4 px-4 py-20 text-center">
        <span class="inline-flex h-20 w-20 items-center justify-center rounded-full bg-white p-3 shadow-sm ring-1 ring-warm/10">
            <Image src={logo} alt="" width={96} height={96} loading="eager" class="h-full w-full object-contain" />
        </span>

        <p class="font-display text-6xl font-semibold leading-none text-primary md:text-7xl">404</p>
        <h1 class="font-display text-2xl font-semibold text-warm md:text-3xl">Сторінку не знайдено</h1>
        <p class="max-w-md text-warm/70">
            Схоже, такої сторінки не існує або її перенесли. Перевір адресу або повернись на головну.
        </p>

        <div class="mt-2 flex flex-col gap-3 sm:flex-row">
            <a
                href={base}
                class="inline-flex items-center justify-center rounded-full bg-primary px-7 py-3 font-medium text-white transition hover:bg-accent-red"
            >
                На головну
            </a>
            <a
                href={`${base}catalog/`}
                class="inline-flex items-center justify-center rounded-full border border-warm/20 px-7 py-3 font-medium text-warm transition hover:border-primary hover:text-primary"
            >
                До меню
            </a>
        </div>
    </main>
</Layout>
