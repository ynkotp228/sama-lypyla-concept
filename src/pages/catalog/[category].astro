---
import Layout from '../../layouts/Layout.astro';
import { categories, getProductsByCategory, getTagsForCategory, tagLabels } from '../../data/products';
import ProductsCard from '../../components/CatalogCategoryComponents/ProductsCard.astro';
import FilterButton from '../../components/CatalogCategoryComponents/FilterButton.astro';

export function getStaticPaths() {
  return categories.map(cat => ({
    params: { category: cat.slug },
    props: {
      categoryName: cat.name,
      products: getProductsByCategory(cat.slug),
      tags: getTagsForCategory(cat.slug),
    },
  }));
}

const { categoryName, products, tags } = Astro.props;
const base = import.meta.env.BASE_URL;
---
<Layout title={`${categoryName} — Сама Ліпила`}>
  <section class="mx-auto max-w-6xl px-4 py-10 md:py-14">
    <a
      href={`${base}catalog/`}
      class="inline-flex items-center gap-1.5 text-sm font-medium text-warm/60 transition hover:text-primary"
    >
      <span aria-hidden="true">←</span> Усе меню
    </a>

    <h1 class="mt-3 font-display text-3xl font-semibold text-warm sm:text-4xl">{categoryName}</h1>
    <p class="mt-1 text-warm/60">{products.length} позицій</p>

    {tags.length > 0 && (
      <div class="mt-6 flex flex-wrap gap-2">
        <FilterButton filter="all" label="Усі" active />
        {tags.map(tag => <FilterButton filter={tag} label={tagLabels[tag]} />)}
      </div>
    )}

    <div class="mt-8 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {products.map(product => <ProductsCard product={product} />)}
    </div>
  </section>

  <script>
    // 1. Усі кнопки фільтра і всі карточки.
    const buttons = document.querySelectorAll<HTMLButtonElement>('[data-filter]');
    const cards = document.querySelectorAll<HTMLElement>('.product-card');

    // 2. Клік на кнопку.
    buttons.forEach(button => {
      button.addEventListener('click', () => {
        const filter = button.dataset.filter;
        if (!filter) return;

        // 3. Кожна карточка: показати ("all" або є тег) чи сховати.
        cards.forEach(card => {
          const cardTags = card.dataset.tags?.split(' ') ?? [];
          const show = filter === 'all' || cardTags.includes(filter);
          card.classList.toggle('hidden', !show);
        });

        // 4. Підсвітити активну кнопку (взаємовиключно, як радіо).
        buttons.forEach(b => b.classList.remove('is-active'));
        button.classList.add('is-active');
      });
    });
  </script>
</Layout>
