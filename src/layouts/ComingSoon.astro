---
import Layout from "./Layout.astro";
import { Image } from 'astro:assets';
import logo from '../assets/images/logoSL.png';
const base = import.meta.env.BASE_URL;

interface Props {
    title?: string;
}
const { title } = Astro.props;
---
<Layout title={title ? `${title} — Сама Ліпила` : 'Сторінка в розробці — Сама Ліпила'}>
    <main class="flex flex-1 flex-col items-center justify-center gap-5 px-4 py-20 text-center">
        <span class="inline-flex h-20 w-20 items-center justify-center rounded-full bg-white p-3 shadow-sm ring-1 ring-warm/10">
            <Image src={logo} alt="Логотип бренду «Сама Ліпила»" width={96} height={96} class="h-full w-full object-contain" />
        </span>

        {title && (
            <p class="text-sm font-semibold uppercase tracking-wider text-accent-red">{title}</p>
        )}
        <h1 class="font-display text-3xl font-semibold text-warm md:text-4xl">
            Сторінка в розробці
        </h1>
        <p class="max-w-md text-warm/70">
                Щиро перепрошуємо, ця сторінка ще готується та перебуває в активній розробці.
        </p>

        <!-- Додатковий контент сторінки (напр. форма на /contacts) -->
        <slot />

        <a
            href={base}
            class="mt-2 inline-flex items-center gap-2 rounded-full bg-accent-red px-7 py-3 font-medium text-white transition hover:bg-accent-red-hover"
        >
            <span aria-hidden="true">←</span> Повернутися на головну
        </a>
    </main>
</Layout>
