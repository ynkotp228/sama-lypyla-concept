---
import '../styles/global.css';
// Шрифти бренду — self-hosted через @fontsource (Lora — заголовки, Inter — тіло).
import '@fontsource/lora/400.css';
import '@fontsource/lora/500.css';
import '@fontsource/lora/600.css';
import '@fontsource/lora/700.css';
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '@fontsource/inter/600.css';
import '@fontsource/inter/700.css';
import ogDefault from '../assets/images/MainPageImages/HeroMainPage.webp';
import Header from '../components/LayoutComponents/Header.astro';
import Footer from '../components/LayoutComponents/Footer.astro';

interface Props {
	title?: string;
	description?: string;
	image?: string;
}

const {
	title = 'Сама Ліпила',
	description = 'Сама Ліпила - це магазин домашніх напівфабриків ручної ліпки, що знаходиться у Вінниці та Львові.',
	image = ogDefault.src,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const imageURL = new URL(image, Astro.site);
---

<!doctype html>
<html lang="uk">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/png" sizes="32x32" href={`${import.meta.env.BASE_URL}favicon-32.png`} />
		<link rel="apple-touch-icon" sizes="180x180" href={`${import.meta.env.BASE_URL}apple-touch-icon.png`} />
		<link rel="canonical" href={canonicalURL} />
		<meta name="description" content={description} />
		<!-- Концепт-редизайн реального бренду: тримаємо поза індексом, щоб не плутати з офіційним. -->
		<meta name="robots" content="noindex, nofollow" />
		<meta name="theme-color" content="#fbf6ee" />
		<!-- Open Graph -->
		<meta property="og:type" content="website" />
		<meta property="og:site_name" content="Сама Ліпила" />
		<meta property="og:locale" content="uk_UA" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:image" content={imageURL} />
		<!-- Twitter -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={imageURL} />

		<title>{title}</title>
	</head>
	<body class="flex min-h-dvh flex-col bg-cream text-warm">
		<Header />
		<slot />
		<Footer />
		<script>
			import '../scripts/menu.js'
			import '../scripts/cart.js'
		</script>
	</body>
</html>
