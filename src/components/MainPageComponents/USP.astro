---
import { Picture } from "astro:assets";
import block1 from '../../assets/images/MainPageImages/USPimages/block1.webp';
import block2 from '../../assets/images/MainPageImages/USPimages/block2.webp';
import block3 from '../../assets/images/MainPageImages/USPimages/block3.webp';

const blocks = [
    {
        img: block1,
        alt: "Борошно, яйця та інші продукти на столі",
        title: "Свіжі продукти. Без хитрощів.",
        text: "Беремо те, з чого готують удома: борошно, картоплю, м'ясо, сир, ягоди. Без консервантів, без замінників, без довгих назв у складі. Якщо не покладеш собі в борщ, не покладемо й у вареник.",
    },
    {
        img: block2,
        alt: "Ліпка пельменів руками у рукавичках",
        title: "Ліпимо при тобі",
        text: "У магазині кухня стоїть за склом. Заходь і дивись, як ліпляться вареники, що ти за хвилину забереш додому. Без машин, без конвеєра, без таємниць. Тільки руки і тісто.",
    },
    {
        img: block3,
        alt: "Свіжозліплені пельмені на лотку перед заморозкою",
        title: "Заморозили та чекаємо тебе",
        text: "Як тільки зліпили, одразу в морозильник. Жодних «дозрівань», жодних перевозок туди-сюди. Береш з нашої вітрини, кладеш у свою морозилку. Тобі залишається лише розігріти і сісти за стіл.",
    },
];
---

<section id="USP" class="scroll-mt-20 bg-white py-16 md:py-24">
    <div class="mx-auto max-w-6xl px-4">
        <header class="mb-12 text-center md:mb-16">
            <p class="mb-2 text-sm font-semibold uppercase tracking-wider text-accent-red">
                Виробництво за склом
            </p>
            <h2 class="font-display text-3xl font-semibold text-warm md:text-5xl">
                Як ми робимо твою їжу?
            </h2>
            <p class="mx-auto mt-3 max-w-2xl text-warm/70 md:text-lg">
                Все ліпимо вручну. У тебе на очах. Без хімії та машин.
            </p>
        </header>

        <div class="space-y-12 md:space-y-20">
            {blocks.map((block, i) => (
                <div class="grid items-center gap-8 md:grid-cols-2 md:gap-12">
                    <div class:list={["overflow-hidden rounded-2xl shadow-md", i % 2 === 1 && "md:order-2"]}>
                        <Picture
                            src={block.img}
                            alt={block.alt}
                            widths={[320, 540, 720]}
                            sizes="(min-width: 768px) 45vw, 100vw"
                            formats={['avif', 'webp']}
                            fallbackFormat="webp"
                            class="[&_img]:aspect-4/3 [&_img]:w-full [&_img]:object-cover"
                        />
                    </div>
                    <div class:list={[i % 2 === 1 && "md:order-1"]}>
                        <span class="mb-4 inline-flex h-11 w-11 items-center justify-center rounded-full bg-primary/10 font-display text-lg font-semibold text-accent-red">
                            {i + 1}
                        </span>
                        <h3 class="mb-3 font-display text-2xl font-semibold text-warm md:text-3xl">
                            {block.title}
                        </h3>
                        <p class="text-warm/80 md:text-lg">
                            {block.text}
                        </p>
                    </div>
                </div>
            ))}
        </div>
    </div>
</section>
