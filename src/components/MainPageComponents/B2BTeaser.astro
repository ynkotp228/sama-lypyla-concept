---
import { Picture } from "astro:assets";
import b2bImage from "../../assets/images/MainPageImages/b2b.webp";

interface Benefit {
  value: string;
  label: string;
}

const benefits: Benefit[] = [
  { value: "5 кг", label: "Мінімальний обʼєм" },
  { value: "3×", label: "Доставки на тиждень" },
  { value: "1:1", label: "Особистий менеджер" },
];
const base = import.meta.env.BASE_URL;
---

<section class="bg-deep-blue py-16 text-cream md:py-24">
  <div class="mx-auto max-w-6xl px-4">
    <div class="grid gap-10 md:grid-cols-2 md:items-center md:gap-16">

      <!-- ── Текстовий блок ── -->
      <div>
        <h2 class="font-display text-3xl font-semibold md:text-5xl">
          Співпраця з бізнесом
        </h2>
        <p class="mt-4 text-base leading-relaxed text-cream/85 md:text-lg">
          Поставляємо напівфабрикати ресторанам, кафе, магазинам і закладам харчування у Львові та Вінниці.
        </p>

        <!-- Переваги -->
        <ul class="mt-8 grid grid-cols-3 gap-4 md:mt-10">
          {benefits.map((b) => (
            <li>
              <p class="font-display text-3xl font-semibold text-primary md:text-4xl">
                {b.value}
              </p>
              <p class="mt-1 text-sm leading-snug text-cream/70">
                {b.label}
              </p>
            </li>
          ))}
        </ul>

        <!-- CTA -->
        <a
          href={`${base}wholesale/`}
          class="mt-10 inline-flex items-center gap-2 rounded-full bg-primary px-7 py-3.5 font-medium text-white shadow-lg shadow-black/10 transition hover:bg-accent-red"
        >
          Обговорити поставки
          <span aria-hidden="true">→</span>
        </a>
      </div>

      <!-- ── Візуал ── -->
      <div>
        <Picture
          src={b2bImage}
          alt="Велика партія напівфабрикатів готується до відправки в заклад"
          widths={[400, 600, 800]}
          sizes="(min-width: 768px) 50vw, 100vw"
          formats={['avif', 'webp']}
          class="overflow-hidden rounded-2xl shadow-xl [&_img]:aspect-4/3 [&_img]:w-full [&_img]:object-cover"
        />
      </div>
    </div>
  </div>
</section>
