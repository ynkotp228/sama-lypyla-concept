---
import ProductCard from "./ProductCard.astro"
import { getHits } from "../../data/products";
const hits = getHits(4);
---


<section>
  <h2>Те, що беруть найчастіше</h2>
  <p>Якщо не знаєш, з чого почати — почни звідси.</p>
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
    {hits.map((product) => <ProductCard product={product} />)}
  </div>
</section>