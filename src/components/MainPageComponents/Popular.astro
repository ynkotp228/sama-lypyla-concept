---
import ProductCard from "./ProductCard.astro"
import { getHits } from "../../data/products";
const base = import.meta.env.BASE_URL;
const hits = getHits(4);
---

<section class="mx-auto max-w-6xl px-4 py-16 md:py-24">
  <header class="mb-10 text-center md:mb-12">
    <h2 class="font-display text-3xl font-semibold text-warm md:text-4xl">
      Те, що беруть найчастіше
    </h2>
    <p class="mx-auto mt-3 max-w-xl text-warm/70">
      Якщо не знаєш, з чого почати — почни звідси.
    </p>
  </header>

  <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
    {hits.map((product) => <ProductCard product={product} />)}
  </div>

  <div class="mt-10 text-center">
    <a
      href={`${base}catalog/`}
      class="inline-flex items-center gap-2 font-medium text-primary transition hover:text-accent-red"
    >
      Усе меню
      <span aria-hidden="true">→</span>
    </a>
  </div>
</section>
