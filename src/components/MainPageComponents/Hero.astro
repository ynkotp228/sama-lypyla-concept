---
import { Picture } from "astro:assets";
import { Image } from "astro:assets";
import heroMainPage from '../../assets/images/MainPageImages/HeroMainPage.webp';
import logoSL from '../../assets/images/logoSL.png';
const base = import.meta.env.BASE_URL;
---
<section class="relative isolate overflow-hidden">
	<!-- Фонове фото топ-продукту -->
	<div class="absolute inset-0 -z-10">
		<Picture
			src={heroMainPage}
			alt="Апетитні пельмені у тарілці"
			widths={[480, 768, 1080, 1440, heroMainPage.width]}
			sizes="100vw"
			formats={['avif', 'webp']}
			fallbackFormat="webp"
			loading="eager"
			fetchpriority="high"
			class="h-full w-full [&_img]:h-full [&_img]:w-full [&_img]:object-cover"
		/>
		<!-- Затемнення для читабельності тексту -->
		<div class="absolute inset-0 bg-linear-to-t from-warm/90 via-warm/60 to-warm/40"></div>
	</div>

	<div class="mx-auto flex min-h-[80vh] max-w-3xl flex-col items-center justify-center gap-5 px-4 py-24 text-center text-cream">
		<!-- Лого на кремовому "медальйоні" — лишається видимим на будь-якому фоні -->
		<span class="inline-flex h-24 w-24 items-center justify-center rounded-full bg-cream/95 p-3 shadow-lg">
			<Image src={logoSL} alt="Логотип Сама Ліпила" width={120} height={120} class="h-full w-full object-contain" />
		</span>

		<h1 class="font-display text-4xl font-semibold leading-tight drop-shadow-sm sm:text-5xl md:text-6xl">
			Напівфабрикат може бути якісним
		</h1>

		<p class="max-w-xl text-base text-cream/90 sm:text-lg">
			Ліпимо вручну, у тебе на очах. Запас домашньої їжі у твоїй морозилці.
			Саме на той день, коли не хочеш готувати, але хочеш по-домашньому.
		</p>

		<div class="mt-3 flex flex-col gap-3 sm:flex-row">
			<a
				href={`${base}catalog/`}
				class="inline-flex items-center justify-center gap-2 rounded-full bg-accent-red px-8 py-3.5 font-medium text-white shadow-lg shadow-warm/20 transition hover:bg-accent-red-hover"
			>
				До меню
				<span aria-hidden="true">→</span>
			</a>
			<a
				href="#USP"
				class="inline-flex items-center justify-center rounded-full border border-cream/70 px-8 py-3.5 font-medium text-cream transition hover:bg-cream hover:text-warm"
			>
				Як ми робимо
			</a>
		</div>
	</div>
</section>
