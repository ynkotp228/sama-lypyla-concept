---
interface Testimonial {
  name: string;
  city: string;
  initial: string;
  text: string;
}

const testimonials: Testimonial[] = [
  {
    name: "Олена",
    city: "Львів",
    initial: "О",
    text: "Вареники з картоплею беру вже, мабуть, півроку. Тісто тонке, не розлазиться, коли варю. Син тепер вимагає їх щовихідних, я вже подумую, чи не брати оптом (жартую... хоча ні, не дуже).",
  },
  {
    name: "Дмитро",
    city: "Вінниця",
    initial: "Д",
    text: "Пельмені беру десь раз на два тижні, коли лінь готувати самому. М'яса реально багато, не як в магазині, де сама вода. Ціна трохи кусається, дружина каже, дешевше самій ліпити, але кому зараз охота з тим тістом возитися.",
  },
  {
    name: "Ірина",
    city: "Львів",
    initial: "І",
    text: "Замовляю з доставкою десь раз на тиждень, після роботи вже ні на що сил нема. Курʼєр привозить у термосумці, все ще заморожене доїжджає. От тільки доводиться ховати від дітей, бо інакше половина зникає ще до вечері.",
  },
];
---

<section class="py-16 md:py-24">
  <div class="mx-auto max-w-6xl px-4">

    <header class="mb-12 text-center md:mb-16">
      <h2 class="font-display text-3xl font-semibold text-warm md:text-5xl">
        Що пишуть наші покупці
      </h2>
      <p class="mt-3 text-base text-warm/70 md:text-lg">
        Без редагування. Як написали — так і залишили.
      </p>
    </header>

    <ul class="grid grid-cols-1 gap-6 md:grid-cols-3 md:gap-8">
      {testimonials.map((t) => (
        <li class="flex flex-col gap-4 rounded-2xl bg-white p-6 shadow-sm ring-1 ring-warm/10 md:p-8">

          <header class="flex items-center gap-3">
            <span
              class="flex h-12 w-12 items-center justify-center rounded-full bg-accent-red text-lg font-medium text-white"
              aria-hidden="true"
            >
              {t.initial}
            </span>
            <div>
              <p class="font-medium text-warm">{t.name}</p>
              <p class="text-sm text-warm/60">{t.city}</p>
            </div>
          </header>

          <div class="flex gap-0.5 text-primary" aria-label="Оцінка 5 з 5">
            {[1, 2, 3, 4, 5].map(() => (
              <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.462a1 1 0 00.95-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>

          <p class="text-base leading-relaxed text-warm/80">
            {t.text}
          </p>
        </li>
      ))}
    </ul>
  </div>
</section>
