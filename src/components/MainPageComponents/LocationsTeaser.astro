---
const base = import.meta.env.BASE_URL;

const cities = [
  { name: "Львів", points: "5 точок у місті", anchor: "lviv" },
  { name: "Вінниця", points: "18 точок у місті", anchor: "vinnytsia" },
];
---

<section class="py-16 md:py-24" aria-labelledby="locations-heading">
  <div class="container mx-auto max-w-5xl px-4">
    <header class="mb-12 text-center">
      <h2 id="locations-heading" class="font-display text-3xl font-semibold text-warm md:text-5xl">
        Заходь до нас
      </h2>
      <p class="mx-auto mt-3 max-w-2xl text-lg text-warm/70">
        У Львові 5 точок, у Вінниці — 18. Обери найближчу.
      </p>
    </header>

    <div class="mb-10 grid gap-6 md:grid-cols-2">
      {cities.map((city) => (
        <a
          href={`${base}locations/#${city.anchor}`}
          class="group block rounded-2xl border border-warm/10 bg-white p-8 transition hover:border-primary hover:shadow-lg"
        >
          <div class="flex items-start justify-between gap-4">
            <div>
              <h3 class="mb-2 font-display text-3xl font-semibold text-warm">{city.name}</h3>
              <p class="text-warm/70">{city.points}</p>
            </div>
            <span
              class="text-2xl text-primary transition group-hover:translate-x-1"
              aria-hidden="true"
            >→</span>
          </div>
        </a>
      ))}
    </div>

    <div class="text-center">
      <a
        href={`${base}locations/`}
        class="inline-flex items-center gap-2 font-medium text-primary transition hover:text-accent-red"
      >
        Усі локації
        <span aria-hidden="true">→</span>
      </a>
    </div>
  </div>
</section>
