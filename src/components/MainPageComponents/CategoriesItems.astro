---
import { Picture } from 'astro:assets';
import type { Category } from '../../data/products';

interface Props {
    category: Category;
}
const { category } = Astro.props;

const base = import.meta.env.BASE_URL;
const url = `${base}catalog/${category.slug}/`;
---

<a
    href={url}
    class="group relative block overflow-hidden rounded-2xl shadow-sm ring-1 ring-warm/10 transition duration-300 hover:shadow-xl"
>
    <Picture
        src={category.image}
        alt={category.alt}
        widths={[200, 300, 420]}
        sizes="(min-width: 1024px) 280px, (min-width: 640px) 45vw, 100vw"
        formats={['avif', 'webp']}
        class="[&_img]:aspect-square [&_img]:h-full [&_img]:w-full [&_img]:object-cover [&_img]:transition-transform [&_img]:duration-500 group-hover:[&_img]:scale-105"
    />
    <!-- Затемнення знизу під підпис -->
    <div class="absolute inset-0 bg-linear-to-t from-warm/85 via-warm/20 to-transparent"></div>
    <h3 class="absolute inset-x-0 bottom-0 p-4 text-center font-display text-lg font-semibold text-cream sm:text-xl">
        {category.name}
    </h3>
</a>
