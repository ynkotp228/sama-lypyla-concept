---
import { Picture } from 'astro:assets';
import type { Category } from '../../data/products';

interface Props {
    category: Category;
}
const { category } = Astro.props;

const base = import.meta.env.BASE_URL;
const url = `${base}catalog/category/${category.slug}`;
---

<a href={url} id={category.slug} class="group block overflow-hidden rounded-lg">
    <Picture
        src={category.image}
        alt={category.alt}
        class="block aspect-square w-full object-cover transition-transform duration-300 group-hover:scale-105"
    />
    <div>
        <h3 class="mt-2 text-center font-medium">{category.name}</h3>
    </div>
</a>
