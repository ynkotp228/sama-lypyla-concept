---
interface Step {
  number: string;
  title: string;
  description: string;
}

const steps: Step[] = [
  {
    number: "01",
    title: "Обрати",
    description: "Переглянь меню, додай в кошик улюблене.",
  },
  {
    number: "02",
    title: "Додати в кошик",
    description: "Збери замовлення у кілька кліків.",
  },
  {
    number: "03",
    title: "Надіслати",
    description: "Зв'яжись з нами — сайтом, у Telegram або дзвінком.",
  },
  {
    number: "04",
    title: "Забрати",
    description: "Самовивіз з нашої точки або доставка додому.",
  },
];
---

<section class="bg-white py-16 md:py-24">
  <div class="mx-auto max-w-4xl px-4">
    <header class="mb-10 text-center md:mb-14">
      <h2 class="font-display text-3xl font-semibold text-warm md:text-5xl">
        Як замовити
      </h2>
      <p class="mt-3 text-warm/70">
        Чотири кроки — і вечеря у твоїй морозилці.
      </p>
    </header>

    <ol class="space-y-0">
      {steps.map((step, index) => (
        <li
          class:list={[
            "grid grid-cols-[auto_1fr] items-baseline gap-6 py-8 md:gap-10 md:py-10",
            index !== steps.length - 1 && "border-b border-warm/10",
          ]}
        >
          <span
            class="font-display text-5xl leading-none text-primary md:text-7xl"
            aria-hidden="true"
          >
            {step.number}
          </span>
          <div>
            <h3 class="mb-2 font-display text-2xl font-semibold text-warm md:text-3xl">
              {step.title}
            </h3>
            <p class="text-base text-warm/70 md:text-lg">
              {step.description}
            </p>
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>
