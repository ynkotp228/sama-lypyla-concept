---
import { Picture } from "astro:assets";
import type { Product } from "../../data/products";

interface Props {
    product: Product;
}

const { product } = Astro.props;
const base = import.meta.env.BASE_URL;
// Окремої сторінки товару немає (опис — через <details> у каталозі),
// тому картка-тизер веде на сторінку своєї категорії.
const url = `${base}catalog/${product.category}/`;
---
<a
    href={url}
    class="group flex flex-col overflow-hidden rounded-2xl bg-white shadow-sm ring-1 ring-warm/10 transition duration-300 hover:-translate-y-1 hover:shadow-xl"
>
    <div class="relative overflow-hidden">
        <Picture
            src={product.image}
            alt={product.alt}
            widths={[280, 350, 600]}
            sizes="(min-width: 1024px) 280px, (min-width: 640px) 45vw, 100vw"
            formats={['avif', 'webp']}
            loading="lazy"
            class="[&_img]:aspect-4/3 [&_img]:w-full [&_img]:object-cover [&_img]:transition-transform [&_img]:duration-500 group-hover:[&_img]:scale-105"
        />
        {product.isHit && (
            <span class="absolute left-3 top-3 rounded-full bg-accent-red px-2.5 py-1 text-xs font-semibold text-white shadow">
                Хіт
            </span>
        )}
    </div>
    <div class="flex flex-1 flex-col gap-1 p-4">
        <h3 class="font-medium text-warm">{product.name}</h3>
        <p class="text-sm text-warm/60">{product.weight}</p>
        <p class="mt-1 font-display text-lg font-semibold text-warm">{product.price} ₴</p>
    </div>
</a>
