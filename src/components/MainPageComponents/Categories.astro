---
import { categories } from '../../data/products';
import CategoriesItems from "./CategoriesItems.astro";

interface Props {
    title?: string;
    description?: string;
    showHeader?: boolean; // false — коли заголовок дає окремий PageHeader (напр. на /catalog)
}
const {
    title = 'Меню',
    description = 'Обери категорію — і збери запас домашньої їжі у морозилці.',
    showHeader = true,
} = Astro.props;
---

<section class="mx-auto max-w-6xl px-4 py-16 md:py-24">
    {showHeader ? (
        <div class="mb-10 text-center md:mb-14">
            <h2 class="font-display text-3xl font-semibold text-warm md:text-4xl"> {title} </h2>
            {description && (
                <p class="mx-auto mt-3 max-w-xl text-warm/70">{description}</p>
            )}
        </div>
    ) : (
        // Заголовок дає окремий PageHeader (h1), але h3 карток не може йти одразу за h1 —
        // прихований h2 тримає послідовність заголовків (a11y).
        <h2 class="sr-only">Категорії напівфабрикатів</h2>
    )}
    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 md:gap-6 lg:grid-cols-4">
        {
            categories.map((category) => (
                <CategoriesItems category={category} />
            ))
        }
    </div>
</section>
