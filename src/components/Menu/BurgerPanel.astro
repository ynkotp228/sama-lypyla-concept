---
// ШАБЛОН: панель, що відкривається + оверлей.
import { links } from '../../data/nav.ts';
---
<div
	id="sidebar-overlay"
	class="pointer-events-none fixed inset-0 z-40 bg-black/50 opacity-0 backdrop-blur-sm transition-opacity duration-300 is-open:pointer-events-auto is-open:opacity-100 lg:hidden"
	aria-hidden="true"
>
</div>

<!--
	Панель. id="sidebar" — НЕ міняй.
	┌ базові:   fixed z-50 flex flex-col bg-white text-black transition-transform duration-300
	├ розмір:   h-full w-72 max-w-[85vw]   ← для sidebar
	├ позиція:  left-0 top-0               ← звідки росте
	├ закрито:  -translate-x-full          ← де ховається (за лівим краєм)
	└ відкрито: is-open:translate-x-0       ← куди їде при is-open
	Щоб зробити меню "зверху-вниз" — заміни 3 останні рядки (див. md-файл).
-->
<aside
	id="sidebar"
	class="fixed z-50 flex flex-col bg-white text-black shadow-2xl transition-transform duration-300 ease-out
	       h-full w-72 max-w-[85vw]
	       left-0 top-0
	       -translate-x-full
	       is-open:translate-x-0
	       lg:hidden"
	aria-hidden="true"
>
	<div class="flex items-center justify-between border-b border-white/10 px-6 py-5">
		<span class="font-display text-lg font-semibold">Сама ліпила</span>

		 
		<button
			type="button"
			id="sidebar-close"
			aria-label="Закрити меню"
			class="inline-flex h-9 w-9 items-center justify-center rounded-full transition hover:bg-black/10"
		>
			<svg
				xmlns="http://www.w3.org/2000/svg"
				width="22"
				height="22"
				viewBox="0 0 24 24"
				fill="none"
				stroke="currentColor"
				stroke-width="2"
				stroke-linecap="round"
				stroke-linejoin="round"
				aria-hidden="true"
			>
				<line x1="18" y1="6" x2="6" y2="18"></line>
				<line x1="6" y1="6" x2="18" y2="18"></line>
			</svg>
		</button>
	</div>

	 
	<nav class="flex flex-1 flex-col gap-1 px-4 py-6">
		{
		links.map(link => (
			<a
				href={link.href}
				class="block rounded-lg px-3 py-2 text-sm transition hover:bg-black/10"
			>
				{link.name}
			</a>
		))}
	</nav>
</aside>
