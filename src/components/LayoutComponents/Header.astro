---
import { Image } from "astro:assets";
import BurgerButton from "../Menu/BurgerButton.astro";
import BurgerPanel from "../Menu/BurgerPanel.astro";
import DesktopNav from "../Menu/Desktop.Nav.astro";
import logo from '../../assets/images/logoSL.png';

const base = import.meta.env.BASE_URL;
const cartHref = `${base}cart/`;
---
<header class="sticky top-0 z-30 border-b border-warm/10 bg-cream/85 backdrop-blur-md">
	<div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-4 py-2.5">
		<!-- Лого + назва бренду -->
		<a
			href={base}
			class="flex shrink-0 items-center gap-2.5 transition hover:opacity-80"
			aria-label="Сама Ліпила — на головну"
		>
			<Image src={logo} alt="" width={88} height={88} class="h-11 w-11 object-contain" />
			<span class="font-display text-lg font-semibold tracking-tight text-warm sm:text-xl">
				Сама Ліпила
			</span>
		</a>

		<div class="flex items-center gap-1 sm:gap-2">
			<DesktopNav />

			<!-- Кошик: іконка + лічильник (з'являється коли в кошику ≥1 позиції). -->
			<a
				href={cartHref}
				class="relative inline-flex h-11 w-11 items-center justify-center rounded-full text-warm transition hover:bg-warm/5 hover:text-accent-red"
				aria-label="Кошик"
			>
				<svg
					xmlns="http://www.w3.org/2000/svg"
					width="22"
					height="22"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="2"
					stroke-linecap="round"
					stroke-linejoin="round"
					aria-hidden="true"
				>
					<circle cx="8" cy="21" r="1"></circle>
					<circle cx="19" cy="21" r="1"></circle>
					<path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"></path>
				</svg>
				<span
					id="cart-count"
					class="absolute -right-0.5 -top-0.5 inline-flex h-5 min-w-5 items-center justify-center rounded-full bg-accent-red px-1 text-[11px] font-semibold text-white"
					hidden
				>0</span>
			</a>

			<BurgerButton />
		</div>
	</div>
</header>
<BurgerPanel />
<script>
	import { getCartCount } from '../../scripts/cart.js';

  const countEl = document.getElementById('cart-count');

  function updateCounter() {
    if (!countEl) return;
    const count = getCartCount();
    if (count > 0) {
      countEl.textContent = String(count);
      countEl.hidden = false;
    } else {
      countEl.hidden = true;
    }
  }

  // 1. Оновити при завантаженні (Astro генерує HTML без LS,
  //    тому при першому рендері counter не знає скільки в кошику)
  updateCounter();

  // 2. Оновлювати при кожній зміні кошика
  window.addEventListener('cart-updated', updateCounter);
  window.addEventListener('storage', (e) => {
  if (e.key === 'sama-lipyla-cart') updateCounter();
});
</script>
