---
import { Image } from "astro:assets";
import logo from '../../assets/images/logoSL.png';
const base = import.meta.env.BASE_URL;
const currentYear = new Date().getFullYear();
---

<footer class="mt-20 bg-warm text-cream" id="footer">
  <div class="container mx-auto max-w-6xl px-4 py-16">

    <!-- ===== Верхня частина: 4 колонки ===== -->
    <div class="mb-12 grid grid-cols-1 gap-10 md:grid-cols-2 lg:grid-cols-4">

      <!-- Колонка 1: Бренд -->
      <div>
        <a href={base} class="mb-4 inline-flex items-center gap-2.5" aria-label="Сама Ліпила — на головну">
          <Image src={logo} width={64} height={64} alt="" class="h-12 w-12 object-contain" />
          <span class="font-display text-lg font-semibold">Сама Ліпила</span>
        </a>

        <p class="mb-3 font-display text-lg text-cream">
          Напівфабрикат може бути якісним
        </p>

        <p class="text-sm text-cream/70">
          Заморожені напівфабрикати ручної роботи
          у Львові та Вінниці.
        </p>
      </div>

      <!-- Колонка 2: Зв'язатися -->
      <div>
        <h2 class="mb-4 text-xs uppercase tracking-wider text-cream/60">
          Зв'язатися
        </h2>

        <!-- Оптові поставки — акцентом бренду -->
        <a
          href={`${base}wholesale/`}
          class="mb-4 inline-flex items-center gap-1 font-medium text-accent-red transition hover:underline"
        >
          Оптові поставки
          <span aria-hidden="true">→</span>
        </a>

        <address class="space-y-2 text-sm not-italic text-cream/80">
          <div>
            <a href="tel:+380961234567" class="transition hover:text-accent-red">
              +380 96 123 4567
            </a>
          </div>
          <div>
            <a href="mailto:samalipyla@example.com" class="transition hover:text-accent-red">
              samalipyla@example.com
            </a>
          </div>
          <div class="text-cream/60">
            Щодня 9:00–21:00
          </div>
        </address>
      </div>

      <!-- Колонка 3: Навігація сайту -->
      <nav aria-label="Навігація у футері">
        <h2 class="mb-4 text-xs uppercase tracking-wider text-cream/60">
          Сайт
        </h2>
        <ul class="space-y-2 text-sm text-cream/80">
          <li><a href={`${base}catalog/`} class="transition hover:text-accent-red">Меню</a></li>
          <li><a href={`${base}locations/`} class="transition hover:text-accent-red">Локації</a></li>
          <li><a href={`${base}about/`} class="transition hover:text-accent-red">Про нас</a></li>
          <li><a href={`${base}contacts/`} class="transition hover:text-accent-red">Контакти</a></li>
        </ul>
      </nav>

      <!-- Колонка 4: Соцмережі -->
      <div>
        <h2 class="mb-4 text-xs uppercase tracking-wider text-cream/60">
          Ми у соцмережах
        </h2>
        <ul class="space-y-2 text-sm text-cream/80">
          <li>
            <a
              href="https://www.instagram.com/samalipyla/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 transition hover:text-accent-red"
            >
              <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="2" y="2" width="20" height="20" rx="5"></rect>
                <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
                <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
              </svg>
              Instagram
              <span class="text-xs text-cream/50">(головний канал)</span>
            </a>
          </li>
          <li>
            <a
              href="https://www.facebook.com/SamaLipylaVinnytsia/reels/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 transition hover:text-accent-red"
            >
              <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path>
              </svg>
              Facebook <span class="text-xs text-cream/50">(Вінниця)</span>
            </a>
          </li>
        </ul>
      </div>

    </div>

    <!-- ===== Нижня полоса ===== -->
    <div class="space-y-3 border-t border-cream/15 pt-8 text-xs text-cream/70">

      <div class="flex flex-col gap-2 sm:flex-row sm:justify-between">
        <p>© {currentYear} Сама Ліпила</p>
        <a href={`${base}privacy/`} class="transition hover:text-accent-red">
          Політика конфіденційності
        </a>
      </div>

      <p class="text-cream/50">
        Концепт-редизайн існуючого бренду. Навчальний проєкт для портфоліо.
        Не пов'язаний з офіційною студією Сама Ліпила.
      </p>
      <p class="text-cream/50">
        Відгуки на сторінці наведені як приклад для концепт-редизайну,
        а не реальні відгуки покупців.
      </p>

    </div>
  </div>
</footer>
