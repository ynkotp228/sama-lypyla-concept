---
// Кнопка фільтра. data-filter — значення тега (або "all" для "Усі").
// Скрипт у [category].astro читає data-filter і ховає/показує карточки.
interface Props {
  filter: string;   // "all" | ProductTag
  label: string;    // людська підпис, напр. "М'ясне"
  active?: boolean;  // початково активна кнопка (зазвичай "Усі")
}

const { filter, label, active = false } = Astro.props;
---

<button
  type="button"
  data-filter={filter}
  class:list={[
    "rounded-full border border-warm/20 px-4 py-1.5 text-sm font-medium text-warm/80 transition-colors",
    "hover:border-primary hover:text-primary",
    "[&.is-active]:border-primary [&.is-active]:bg-primary [&.is-active]:text-white",
    { "is-active": active },
  ]}
>
  {label}
</button>
