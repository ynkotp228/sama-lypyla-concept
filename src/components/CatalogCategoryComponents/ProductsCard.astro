---
// src/components/CatalogCategoryComponents/ProductsCard.astro
import { Picture } from 'astro:assets';
import { tagLabels, type Product } from '../../data/products.ts';

interface Props {
  product: Product;
  priority?: boolean; // true для карток першого ряду — щоб LCP-картинка не була lazy
}

const { product, priority = false } = Astro.props;
// data-tags — кирпич №1 фільтра: теги одним рядком через пробіл.
const tags = (product.tags ?? []).join(' ');

// Бейджі: максимум 2. Пріоритет — Хіт → Новинка → найхарактерніший тег.
type Badge = { label: string; kind: 'hit' | 'new' | 'tag' };
const allBadges: Badge[] = [];
if (product.isHit) allBadges.push({ label: 'Хіт', kind: 'hit' });
if (product.isNew) allBadges.push({ label: 'Новинка', kind: 'new' });
const firstTag = product.tags?.[0];
if (firstTag) allBadges.push({ label: tagLabels[firstTag], kind: 'tag' });
const badges = allBadges.slice(0, 2);

const badgeClass: Record<Badge['kind'], string> = {
  hit: 'bg-accent-red text-white',
  new: 'bg-deep-blue text-white',
  tag: 'bg-cream text-warm ring-1 ring-warm/15',
};
---

<article
  class="product-card group flex flex-col overflow-hidden rounded-2xl bg-white shadow-sm ring-1 ring-warm/10 transition duration-300 hover:shadow-lg"
  data-tags={tags}
>
  <div class="relative overflow-hidden">
    <Picture
      src={product.image}
      widths={[280, 350, 600]}
      sizes="(min-width: 1024px) 280px, (min-width: 640px) 45vw, 100vw"
      formats={['avif', 'webp']}
      fallbackFormat="webp"
      alt={product.alt}
      loading={priority ? 'eager' : 'lazy'}
      fetchpriority={priority ? 'high' : 'auto'}
      class="[&_img]:aspect-4/3 [&_img]:w-full [&_img]:object-cover [&_img]:transition-transform [&_img]:duration-500 group-hover:[&_img]:scale-105"
    />
    {badges.length > 0 && (
      <div class="absolute left-3 top-3 flex flex-wrap gap-1.5">
        {badges.map((b) => (
          <span class:list={["rounded-full px-2.5 py-1 text-xs font-semibold shadow-sm", badgeClass[b.kind]]}>
            {b.label}
          </span>
        ))}
      </div>
    )}
  </div>

  <div class="flex flex-1 flex-col gap-2 p-4">
    <h3 class="font-medium text-warm">{product.name}</h3>
    <p class="text-sm text-warm/60">
      {product.weight} · <span class="font-semibold text-warm">{product.price} ₴</span>
    </p>

    {product.description && (
      <details class="text-sm text-warm/70">
        <summary class="cursor-pointer list-none font-medium text-accent-red transition hover:underline [&::-webkit-details-marker]:hidden">
          Детальніше
        </summary>
        <p class="mt-2 leading-relaxed">{product.description}</p>
      </details>
    )}

    <button
      type="button"
      data-product-id={product.id}
      aria-label={`Додати ${product.name} в кошик`}
      class="mt-auto rounded-lg bg-accent-red px-3 py-2.5 text-sm font-medium text-white transition-colors hover:bg-accent-red-hover"
    >
      + в кошик
    </button>
  </div>
</article>

<style>
  /* Стан "додано в кошик": зелений — універсальний колір успіху.
     Навмисно поза брендовою палітрою, тільки на час фідбеку (1.2с),
     перекриває червоний фон і hover кнопки. */
  .is-added,
  .is-added:hover {
    background-color: var(--color-success-soft); /* green-100 */
    color: var(--color-success);                 /* green-700, текст + галочка */
  }
</style>

<script>
  import { addToCart } from "../../scripts/cart";
   document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    // Своє поле _feedbackTimeout зберігає id таймера на самому елементі —
    // розширюємо тип, щоб strict TS про нього знав.
    const btn = target.closest('button[data-product-id]') as
      | (HTMLButtonElement & { _feedbackTimeout?: ReturnType<typeof setTimeout> })
      | null;
    if (!btn) return;

    const productId = btn.getAttribute('data-product-id');
    if (productId) {
      addToCart(productId);
      clearTimeout(btn._feedbackTimeout);
      btn.classList.add('is-added');
      btn.textContent = 'Додано ✓';

      btn._feedbackTimeout = setTimeout(() => {
      btn.classList.remove('is-added');
      btn.textContent = '+ в кошик';
      }, 1200);
    }
  });
</script>
