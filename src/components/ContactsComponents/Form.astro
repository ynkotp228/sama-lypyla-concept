---
const phonePattern = '^\\+380\\d{9}$';
---

<section class="w-full max-w-lg text-left">
	<div class="rounded-2xl bg-white p-6 shadow-sm ring-1 ring-warm/10 md:p-8">
		<h2 class="font-display text-2xl font-semibold text-warm">Питання, відгуки, пропозиції</h2>
		<p class="mt-2 text-warm/70">
			Залиште своє повідомлення нижче.
		</p>

		<form
			id="ask-form"
			action="https://formspree.io/f/mojzpzne"
			method="POST"
			novalidate
			class="mt-6 space-y-4"
		>
			<div>
				<label for="name" class="mb-1 block text-sm font-medium text-warm">Твоє ім'я</label>
				<input
					type="text"
					id="name"
					name="name"
					minlength="2"
					required
					placeholder="Мінімум 2 символи"
					class="w-full rounded-lg border border-warm/20 bg-white px-3 py-2.5 text-warm placeholder:text-warm/40 transition focus:border-accent-red focus:outline-none focus:ring-2 focus:ring-accent-red/30 aria-[invalid]:border-accent-red"
				/>
				<p class="field-error mt-1 text-sm text-accent-red" data-error-for="name" hidden></p>
			</div>

			<div>
				<label for="tel" class="mb-1 block text-sm font-medium text-warm">Твій номер телефону</label>
				<input
					type="tel"
					id="tel"
					name="tel"
					pattern={phonePattern}
					required
					placeholder="+380XXXXXXXXX"
					class="w-full rounded-lg border border-warm/20 bg-white px-3 py-2.5 text-warm placeholder:text-warm/40 transition focus:border-accent-red focus:outline-none focus:ring-2 focus:ring-accent-red/30 aria-[invalid]:border-accent-red"
				/>
				<p class="field-error mt-1 text-sm text-accent-red" data-error-for="tel" hidden></p>
			</div>

			<div>
				<label for="inquiry-type" class="mb-1 block text-sm font-medium text-warm">Тема звернення</label>
				<select
					id="inquiry-type"
					name="inquiry_type"
					required
					class="w-full rounded-lg border border-warm/20 bg-white px-3 py-2.5 text-warm transition focus:border-accent-red focus:outline-none focus:ring-2 focus:ring-accent-red/30 aria-[invalid]:border-accent-red"
				>
					<option value="" disabled selected hidden>Оберіть тему</option>
					<option value="general">Загальне питання</option>
					<option value="feedback">Відгук або скарга</option>
					<option value="product">Питання про товар (склад, алергени)</option>
					<option value="other">Інше</option>
				</select>
				<p class="field-error mt-1 text-sm text-accent-red" data-error-for="inquiry_type" hidden></p>
			</div>

			<div>
				<label for="message" class="mb-1 block text-sm font-medium text-warm">Твоє повідомлення</label>
				<textarea
					id="message"
					name="message"
					rows="4"
					minlength="10"
					required
					placeholder="Розкажи, що тебе цікавить чи бентежить (мінімум 10 символів)"
					class="w-full rounded-lg border border-warm/20 bg-white px-3 py-2.5 text-warm placeholder:text-warm/40 transition focus:border-accent-red focus:outline-none focus:ring-2 focus:ring-accent-red/30 aria-[invalid]:border-accent-red"
				></textarea>
				<p class="field-error mt-1 text-sm text-accent-red" data-error-for="message" hidden></p>
			</div>
			<!-- Honeypot проти спаму (конвенція Formspree): приховане, поза tab-порядком -->
            <input
              type="text"
              name="_gotcha"
              style="display:none"
              tabindex="-1"
              autocomplete="off"
              aria-hidden="true"
            />
			<button
				type="submit"
				class="w-full rounded-lg bg-accent-red px-4 py-3 font-medium text-white transition hover:bg-accent-red-hover"
			>
				Надіслати
			</button>

			<p
				id="form-status"
				role="status"
				aria-live="polite"
				class="text-sm font-medium data-[state=error]:text-accent-red data-[state=ok]:text-success"
				hidden
			></p>
		</form>
	</div>
</section>

<script>
	const form = document.getElementById("ask-form") as HTMLFormElement | null;
	const status = document.getElementById("form-status");


	if (form && status) {
		const nameInput = form.elements.namedItem("name") as HTMLInputElement;
		const telInput = form.elements.namedItem("tel") as HTMLInputElement;
		const inquiryInput = form.elements.namedItem("inquiry_type") as HTMLSelectElement;
		const messageInput = form.elements.namedItem("message") as HTMLTextAreaElement;

		const show = (msg: string, ok: boolean) => {
			status.textContent = msg;
			status.hidden = false;
			status.dataset.state = ok ? "ok" : "error";
		};

		const setFieldError = (
			input: HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement,
			msg: string,
		) => {
			const errorEl = form.querySelector<HTMLElement>(`[data-error-for="${input.name}"]`);
			if (msg) {
				if (errorEl) {
					errorEl.textContent = msg;
					errorEl.hidden = false;
				}
				input.setAttribute("aria-invalid", "true");
			} else {
				if (errorEl) {
					errorEl.textContent = "";
					errorEl.hidden = true;
				}
				input.removeAttribute("aria-invalid");
			}
		};

		const validateName = (): string => {
			const value = nameInput.value.trim();
			if (!value) return "Будь ласка, введи своє ім'я.";
			if (value.length < 2) return "Ім'я має містити щонайменше 2 символи.";
			return "";
		};

		const validateTel = (): string => {
			const value = telInput.value.trim();
			if (!value) return "Будь ласка, введи номер телефону.";
			if (!new RegExp(telInput.pattern).test(value)) {
				return "Неправильний формат. Введи номер телефону у вигляді +380XXXXXXXXX (12 цифр).";
			}
			return "";
		};

		const validateInquiry = (): string => {
			if (!inquiryInput.value) return "Будь ласка, оберіть тему звернення.";
			return "";
		};

		const validateMessage = (): string => {
			const value = messageInput.value.trim();
			if (!value) return "Будь ласка, опиши своє запитання/повідомлення.";
			if (value.length < 10) {
				return `Повідомлення занадто коротке (мінімум 10 символів, зараз ${value.length}).`;
			}
			return "";
		};

		telInput.addEventListener("focus", () => {
			if (!telInput.value) telInput.value = "+380";
		});

		telInput.addEventListener("blur", () => {
			if (telInput.value === "+380") telInput.value = "";
		});

		nameInput.addEventListener("blur", () => setFieldError(nameInput, validateName()));
		nameInput.addEventListener("input", () => {
			if (nameInput.getAttribute("aria-invalid")) setFieldError(nameInput, validateName());
		});

		telInput.addEventListener("blur", () => {
			if (telInput.value) setFieldError(telInput, validateTel());
		});
		telInput.addEventListener("input", () => {
			if (telInput.getAttribute("aria-invalid")) setFieldError(telInput, validateTel());
		});

		inquiryInput.addEventListener("change", () => setFieldError(inquiryInput, validateInquiry()));

		messageInput.addEventListener("blur", () => setFieldError(messageInput, validateMessage()));
		messageInput.addEventListener("input", () => {
			if (messageInput.getAttribute("aria-invalid")) setFieldError(messageInput, validateMessage());
		});

		form.addEventListener("submit", async (e) => {
			e.preventDefault();

			const errors = {
				name: validateName(),
				tel: validateTel(),
				inquiry: validateInquiry(),
				message: validateMessage(),
			};
			setFieldError(nameInput, errors.name);
			setFieldError(telInput, errors.tel);
			setFieldError(inquiryInput, errors.inquiry);
			setFieldError(messageInput, errors.message);

			const firstInvalid = [nameInput, telInput, inquiryInput, messageInput].find(
				(input) => input.getAttribute("aria-invalid"),
			);
			if (firstInvalid) {
				show("Будь ласка, виправте помилки у формі.", false);
				firstInvalid.focus();
				return;
			}

			const data = new FormData(form);
			try {
				const res = await fetch(form.action, {
					method: "POST",
					body: data,
					headers: { Accept: "application/json" },
				});
				if (res.ok) {
					show("Звернення отримано. Дякуємо!", true);
					form.reset();
				} else {
					show("Не вдалося надіслати. Спробуйте пізніше.", false);
				}
			} catch {
				show("Помилка мережі. Перевірте з'єднання.", false);
			}
		});
	}
</script>
