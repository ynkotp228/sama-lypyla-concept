---
// Блок прямих контактів: телефон, email, графік + кнопка переходу на локації.
const base = import.meta.env.BASE_URL;
---

<section
  aria-labelledby="contacts-heading"
  class="rounded-2xl bg-white p-6 shadow-sm ring-1 ring-warm/10 md:p-8"
>
  <h2 id="contacts-heading" class="font-display text-2xl font-semibold text-warm">
    Як зв'язатися
  </h2>

  <address class="mt-5 space-y-4 not-italic text-warm/80">
    <!-- Телефон -->
    <div class="flex items-center gap-3">
      <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-primary/10 text-primary">
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
        </svg>
      </span>
      <div>
        <p class="text-xs uppercase tracking-wider text-warm/50">Телефон</p>
        <a href="tel:+380961234567" class="text-lg font-medium text-warm transition hover:text-primary">
          +380 96 123 4567
        </a>
      </div>
    </div>

    <!-- Email -->
    <div class="flex items-center gap-3">
      <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-primary/10 text-primary">
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="2" y="4" width="20" height="16" rx="2"></rect>
          <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
        </svg>
      </span>
      <div>
        <p class="text-xs uppercase tracking-wider text-warm/50">Email</p>
        <a href="mailto:samalipyla@example.com" class="text-lg font-medium text-warm transition hover:text-primary">
          samalipyla@example.com
        </a>
      </div>
    </div>

    <!-- Графік -->
    <div class="flex items-center gap-3">
      <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-primary/10 text-primary">
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="10"></circle>
          <polyline points="12 6 12 12 16 14"></polyline>
        </svg>
      </span>
      <div>
        <p class="text-xs uppercase tracking-wider text-warm/50">Графік</p>
        <p class="text-lg font-medium text-warm">Щодня 9:00–21:00</p>
      </div>
    </div>
  </address>

  <!-- Перехід на сторінку локацій -->
  <a
    href={`${base}locations/`}
    class="mt-6 inline-flex items-center gap-2 rounded-lg border border-primary px-4 py-2.5 font-medium text-primary transition hover:bg-primary hover:text-white"
  >
    <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
      <circle cx="12" cy="10" r="3"></circle>
    </svg>
    Знайти точку поруч
    <span aria-hidden="true">→</span>
  </a>
</section>
