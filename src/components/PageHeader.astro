---
// Переиспользуемый Mini-Hero для внутренних страниц.
// Используется на /catalog (и пригоден для /locations, /contacts, /about, /wholesale, /privacy).

interface Props {
  title: string;
  description?: string;
  secondary?: string;
}

const { title, description, secondary } = Astro.props;
---

<header class="border-b border-warm/10 bg-white py-8 md:py-12">
  <div class="container mx-auto max-w-5xl px-4">
    <h1 class="font-display text-4xl font-semibold text-warm md:text-5xl">
      {title}
    </h1>

    {description && (
      <p class="mt-3 max-w-2xl text-lg text-warm/70">
        {description}
      </p>
      <p class="mt-3 max-w-2xl text-lg text-warm/70">
        {secondary}
      </p>
    )}
  </div>
</header>
